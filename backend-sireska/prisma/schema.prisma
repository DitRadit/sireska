generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id    Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  role_name  String   @unique @db.VarChar(30)
  deskripsi  String?  @db.VarChar(120)
  created_at DateTime @default(now())

  users User[]
}

model User {
  user_id        Int      @id @default(autoincrement()) @db.UnsignedInt
  role_id        Int      @db.UnsignedTinyInt

  nim_nip        String?  @unique @db.VarChar(20)   // ← nullable sekarang
  nama_lengkap   String   @db.VarChar(120)
  email          String   @unique @db.VarChar(150)
  password_hash  String   @db.VarChar(255)

  no_hp          String?  @db.VarChar(20)
  foto_ktm_url   String?  @db.VarChar(255)

  is_verified    Boolean  @default(false)
  is_active      Boolean  @default(true)

  last_login     DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  role Role @relation(fields: [role_id], references: [role_id])

  reservasi Reservasi[]

  @@index([role_id])
  @@index([is_verified])
}

model Fasilitas {
  fasilitas_id     Int      @id @default(autoincrement()) @db.UnsignedInt
  nama_fasilitas   String   @db.VarChar(100)
  deskripsi        String?  @db.Text
  lokasi           String?  @db.VarChar(150)
  kapasitas        Int?     @db.UnsignedSmallInt
  harga_per_jam    Decimal? @db.Decimal(10, 2)
  jam_buka         String   @db.VarChar(5)
  jam_tutup        String   @db.VarChar(5)
  gambar_url       String?  @db.VarChar(500)
  gambar_public_id String?  @db.VarChar(255)
  latitude         Float?                    // ← tambahkan
  longitude        Float?                    // ← tambahkan
  status           StatusFasilitas @default(aktif)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  reservasi           Reservasi[]
  slot_tidak_tersedia SlotTidakTersedia[]
}

model Reservasi {
  reservasi_id   Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id        Int      @db.UnsignedInt
  fasilitas_id   Int      @db.UnsignedInt
  // jadwal_id dihapus
  tanggal        DateTime @db.Date
  jam_mulai      String   @db.VarChar(5)   // ← tambahkan
  jam_selesai    String   @db.VarChar(5)   // ← tambahkan
  keperluan      String?  @db.VarChar(255)
  status         StatusReservasi @default(menunggu)
  catatan_admin  String?  @db.VarChar(255)
  dokumen_url        String?  @db.VarChar(500)
  midtrans_order_id  String?  @unique @db.VarChar(100)
  midtrans_qris_url  String?  @db.VarChar(500)
  total_harga        Decimal? @db.Decimal(10, 2)
  status_pembayaran  StatusPembayaran?
  midtrans_qris_img  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user      User      @relation(fields: [user_id], references: [user_id])
  fasilitas Fasilitas @relation(fields: [fasilitas_id], references: [fasilitas_id])
}

model SlotTidakTersedia {
  slot_id      Int      @id @default(autoincrement()) @db.UnsignedInt
  fasilitas_id Int      @db.UnsignedInt
  tanggal      DateTime @db.Date
  jam_mulai    String   @db.VarChar(5)
  jam_selesai  String   @db.VarChar(5)
  keterangan   String?  @db.VarChar(255)
  created_at   DateTime @default(now())

  fasilitas Fasilitas @relation(fields: [fasilitas_id], references: [fasilitas_id], onDelete: Cascade)

  @@index([fasilitas_id])
  @@index([tanggal])
}

enum StatusReservasi {
  menunggu
  disetujui
  ditolak
  selesai        // ← tambah
}

enum StatusFasilitas {
  aktif
  maintenance
  nonaktif
  sedang_digunakan  // ← tambah
}

enum StatusPembayaran {
  belum_bayar
  menunggu_pembayaran
  lunas
  expired
}
