generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id    Int     @id @default(autoincrement()) @db.UnsignedTinyInt
  role_name  String  @unique @db.VarChar(30)
  deskripsi  String? @db.VarChar(120)
  created_at DateTime @default(now())

  users User[]
}

model User {
  user_id        Int      @id @default(autoincrement()) @db.UnsignedInt
  role_id        Int      @db.UnsignedTinyInt

  nim_nip        String   @unique @db.VarChar(20)
  nama_lengkap   String   @db.VarChar(120)
  email          String   @unique @db.VarChar(150)
  password_hash  String   @db.VarChar(255)

  no_hp          String?  @db.VarChar(20)
  foto_ktm_url   String?  @db.VarChar(255)

  is_verified    Boolean  @default(false)
  is_active      Boolean  @default(true)

  last_login     DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  role Role @relation(fields: [role_id], references: [role_id])

  reservasi Reservasi[]

  @@index([role_id])
  @@index([is_verified])
}

model Fasilitas {
  fasilitas_id   Int      @id @default(autoincrement()) @db.UnsignedInt
  nama_fasilitas String   @db.VarChar(100)
  deskripsi      String?  @db.Text
  lokasi         String?  @db.VarChar(150)
  kapasitas      Int?     @db.UnsignedSmallInt
  gambar_url     String?  @db.VarChar(500)
  gambar_public_id String? @db.VarChar(255)

  reservasi Reservasi[]

  status         StatusFasilitas @default(aktif)

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  jadwal         JadwalFasilitas[]
}

model JadwalFasilitas {
  jadwal_id    Int      @id @default(autoincrement()) @db.UnsignedInt
  fasilitas_id Int      @db.UnsignedInt
  hari         HariFasilitas
  jam_buka     String   @db.VarChar(5)
  jam_tutup    String   @db.VarChar(5)

  reservasi Reservasi[]
  
  fasilitas    Fasilitas @relation(fields: [fasilitas_id], references: [fasilitas_id], onDelete: Cascade)

  @@index([fasilitas_id])
}

model Reservasi {
  reservasi_id   Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id        Int      @db.UnsignedInt
  fasilitas_id   Int      @db.UnsignedInt
  jadwal_id      Int      @db.UnsignedInt
  tanggal        DateTime @db.Date
  keperluan      String?  @db.VarChar(255)
  status         StatusReservasi @default(menunggu)
  catatan_admin  String?  @db.VarChar(255)

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user           User      @relation(fields: [user_id], references: [user_id])
  fasilitas      Fasilitas @relation(fields: [fasilitas_id], references: [fasilitas_id])
  jadwal         JadwalFasilitas @relation(fields: [jadwal_id], references: [jadwal_id])

  @@index([user_id])
  @@index([fasilitas_id])
  @@index([jadwal_id])
  @@index([status])
}

enum StatusReservasi {
  menunggu
  disetujui
  ditolak
}

enum StatusFasilitas {
  aktif
  maintenance
  nonaktif
}

enum HariFasilitas {
  senin
  selasa
  rabu
  kamis
  jumat
  sabtu
  minggu
}